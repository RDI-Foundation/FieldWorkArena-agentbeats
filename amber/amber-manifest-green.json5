{
  manifest_version: "0.1.0",
  program: {
    image: "ghcr.io/ast-fri/fieldworkarena-greenagent-fwa-server:latest",
    entrypoint: [
      "uv",
      "run",
      "fwa-server",
      "--host",
      "0.0.0.0",
      "--port",
      "8081"
    ],
    env: {
      PROXY_URL: "${slots.proxy.url}",
      OPENAI_API_KEY: "${config.openai_api_key}",
      HF_TOKEN: "${config.hf_token}",
      LOG_LEVEL: "INFO",
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 8081 },
      ],
    },
  },
  config_schema: {
    type: "object",
    properties: {
      openai_api_key: { type: "string", secret: true },
      hf_token: { type: "string", secret: true }
    },
    required: ["openai_api_key", "hf_token"],
    additionalProperties: false,
  },
  slots: {
    proxy: { kind: "a2a" },
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" },
  },
  exports: {
    a2a: "a2a",
  },
  metadata: {
    assessment_config: { "target": "all" },
    participant_roles: ["agent"]
  }
}
